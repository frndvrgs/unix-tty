---
// Shared footer for terminal-app pages (reader, and any future page that
// wants the same chrome). Renders a desktop hint string and a mobile
// button row, and mounts an init script that wires keyboard shortcuts
// (+, -, ArrowUp, ArrowDown, c, q, Escape) and button clicks to font
// scaling, scrolling, theme cycling, and exit-to-terminal.
//
// Layout: both variants use `justify-content: space-between` so the
// scroll/colors/exit commands sit on the left and the font-size
// controls sit on the right end.
//
// Font scaling mutates a single CSS variable (--reader-font-scale) on
// body.reader; only the article reflows. The footer itself uses absolute
// px units everywhere so it cannot move when the article scales.
---
<footer class="app-footer">
  <div class="app-footer-desktop">
    <span>UP, DOWN: scroll | c: switch colors | q: exit to terminal</span>
    <span>+ - <span data-footer-fontsize>100%</span></span>
  </div>
  <div class="app-footer-mobile">
    <span class="app-footer-group">
      <button type="button" data-footer-action="colors" aria-label="switch colors">colors</button>
      <button type="button" data-footer-action="exit" aria-label="exit to terminal">exit</button>
    </span>
    <span class="app-footer-group">
      <button type="button" data-footer-action="font-inc" aria-label="increase font size">+</button>
      <button type="button" data-footer-action="font-dec" aria-label="decrease font size">−</button>
      <span data-footer-fontsize>100%</span>
    </span>
  </div>
</footer>

<style is:global>
  /*
   * Footer is fixed at the bottom of the viewport. Every dimension here
   * uses absolute units so the footer's geometry is immune to changes in
   * the article's font scale (--reader-font-scale).
   */
  .app-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 16px;
    background: var(--bg);
    border-top: 1px solid var(--dim);
    color: var(--fg);
    font-size: 13px;
    line-height: 1.4;
    z-index: 100;
  }

  .app-footer-desktop,
  .app-footer-mobile {
    display: none;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .app-footer-desktop {
    display: flex;
  }

  @media (max-width: 600px) {
    /*
     * Mobile-only padding override — double the default so the
     * content clears the rounded frame cutouts on phones. Notches
     * and pill cutouts on modern devices eat into the edges; the
     * extra room keeps the buttons and text away from the curve.
     */
    .app-footer {
      padding: 22px 22px 32px 22px;
    }
    .app-footer-desktop {
      display: none;
    }
    .app-footer-mobile {
      display: flex;
    }
  }

  .app-footer-group {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .app-footer-mobile button {
    background: transparent;
    border: 1px solid var(--fg);
    border-radius: 0;
    color: var(--fg);
    font-family: inherit;
    font-size: 13px;
    line-height: 1;
    padding: 5px 10px;
    cursor: pointer;
  }

  /*
   * Hover state is scoped to real pointer devices only. On touch,
   * browsers otherwise stick :hover on the last-tapped button until
   * the user taps elsewhere, making the footer look "stuck". Without
   * this gate, every tap would leave a trailing highlight.
   */
  @media (hover: hover) {
    .app-footer-mobile button:hover {
      background: var(--fg);
      color: var(--bg);
    }
  }

  /*
   * Keyboard-focus feedback. :focus-visible only fires on keyboard
   * navigation (Tab), not on mouse click or touch tap, so it gives
   * keyboard users a clear indicator without introducing the sticky
   * highlight that full :focus would on mobile.
   */
  .app-footer-mobile button:focus-visible,
  .app-footer-mobile button:active {
    background: var(--fg);
    color: var(--bg);
    outline: none;
  }
</style>

<script>
  import { initAppFooter } from 'unix-tty/src/scripts/footer/init.ts';
  initAppFooter();
</script>
