{
  "name": "unix-tty",
  "type": "module",
  "version": "0.4.0",
  "description": "Unix terminal-style website builder as an Astro integration",
  "author": "Fernando Vargas <frndvrgs> (https://frndvrgs.com)",
  "repository": "github:frndvrgs/unix-tty",
  "homepage": "https://github.com/frndvrgs/unix-tty",
  "license": "MIT",
  "keywords": [
    "astro",
    "terminal",
    "tty",
    "unix",
    "monospace",
    "static-site"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "cd example && astro dev",
    "build": "cd example && astro build",
    "preview": "cd example && astro preview",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "exports": {
    "./integration": "./src/integration.ts",
    "./content": "./src/content.ts",
    "./config": "./src/config.ts",
    "./src/*": "./src/*"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "astro": "^6.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.5.2",
    "astro": "^6.1.5",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "web-haptics": "^0.0.6"
  }
}
